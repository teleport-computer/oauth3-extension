{
  "manifest_version": 3,
  "name": "OAuth3",
  "version": "0.1.0",
  "description": "Sync your cookie jar for a site into an OAuth3 instance you trust, so apps get scoped, revocable read access — never your raw cookies.",
  "permissions": ["cookies", "storage", "alarms"],
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "optional_host_permissions": ["https://*/*"],
  "background": { "service_worker": "service-worker.js", "type": "module" },
  "action": { "default_popup": "popup.html", "default_title": "OAuth3" }
}
